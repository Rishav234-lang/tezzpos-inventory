generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== PLATFORM MODELS ====================

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(10, 2)
  description  String?
  status       PlanStatus @default(ACTIVE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions CompanySubscription[]

  @@map("plans")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  phone     String?
  address   String?
  gstNumber String?       @map("gst_number")
  status    CompanyStatus @default(PENDING)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  owner         Owner?
  subscription  CompanySubscription?
  counter       CompanyCounter?
  payments      SubscriptionPayment[]
  vendors       Vendor[]
  products      Product[]
  categories    Category[]
  purchases     Purchase[]
  batches       Batch[]
  customers     Customer[]
  sales         Sale[]
  salesReturns  SaleReturn[]
  customerPayments CustomerPayment[]
  vendorPayments   VendorPayment[]
  stockAdjustments StockAdjustment[]

  @@index([status])
  @@index([email])
  @@map("companies")
}

model Owner {
  id        String   @id @default(cuid())
  companyId String   @unique @map("company_id")
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("owners")
}

model CompanySubscription {
  id                    String              @id @default(cuid())
  companyId             String              @unique @map("company_id")
  planId                String              @map("plan_id")
  customPrice           Decimal?            @map("custom_price") @db.Decimal(10, 2)
  billingCycle          BillingCycle        @default(MONTHLY) @map("billing_cycle")
  startDate             DateTime            @map("start_date")
  endDate               DateTime            @map("end_date")
  razorpaySubscriptionId String?            @map("razorpay_subscription_id")
  autoRenew             Boolean             @default(true) @map("auto_renew")
  status                SubscriptionStatus  @default(TRIAL)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan    @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@index([companyId])
  @@index([status])
  @@index([endDate])
  @@map("company_subscriptions")
}

model SubscriptionPayment {
  id                 String        @id @default(cuid())
  companyId          String        @map("company_id")
  subscriptionId     String        @map("subscription_id")
  amount             Decimal       @db.Decimal(10, 2)
  paymentDate        DateTime      @map("payment_date")
  razorpayPaymentId  String?       @map("razorpay_payment_id")
  status             PaymentStatus @default(PENDING)
  createdAt          DateTime      @default(now()) @map("created_at")

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription CompanySubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([subscriptionId])
  @@map("subscription_payments")
}

// ==================== COMPANY MODELS ====================

model Category {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Vendor {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  mobile    String?
  gstNumber String?  @map("gst_number")
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchases  Purchase[]
  batches    Batch[]
  payments   VendorPayment[]

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, mobile])
  @@map("vendors")
}

model Product {
  id              String        @id @default(cuid())
  companyId       String        @map("company_id")
  categoryId      String?       @map("category_id")
  name            String
  sku             String?
  barcode         String?
  unit            String        @default("PCS")
  hsnCode         String?       @map("hsn_code")
  gstRate         Decimal       @default(0) @map("gst_rate") @db.Decimal(5, 2)
  sellingPrice    Decimal       @map("selling_price") @db.Decimal(10, 2)
  minStockLevel   Int           @default(10) @map("min_stock_level")
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id])
  batches        Batch[]
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
  returnItems    SaleReturnItem[]
  adjustments    StockAdjustment[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, status])
  @@index([companyId, categoryId])
  @@map("products")
}

model Purchase {
  id            String         @id @default(cuid())
  companyId     String         @map("company_id")
  vendorId      String         @map("vendor_id")
  invoiceNumber String         @map("invoice_number")
  purchaseDate  DateTime       @map("purchase_date")
  totalAmount   Decimal        @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount Decimal        @default(0) @map("balance_amount") @db.Decimal(12, 2)
  status        InvoiceStatus  @default(UNPAID)
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor   Vendor         @relation(fields: [vendorId], references: [id])
  items    PurchaseItem[]
  batches  Batch[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, vendorId])
  @@index([companyId, purchaseDate])
  @@index([companyId, status])
  @@map("purchases")
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String   @map("purchase_id")
  productId     String   @map("product_id")
  quantity      Int
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  mrp           Decimal  @db.Decimal(10, 2)
  expiryDate    DateTime? @map("expiry_date")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Batch {
  id                String      @id @default(cuid())
  companyId         String      @map("company_id")
  productId         String      @map("product_id")
  vendorId          String      @map("vendor_id")
  purchaseId        String      @map("purchase_id")
  batchNumber       String      @map("batch_number")
  purchaseDate      DateTime    @map("purchase_date")
  purchasePrice     Decimal     @map("purchase_price") @db.Decimal(10, 2)
  mrp               Decimal     @db.Decimal(10, 2)
  expiryDate        DateTime?   @map("expiry_date")
  purchasedQuantity Int         @map("purchased_quantity")
  availableQuantity Int         @map("available_quantity")
  status            BatchStatus @default(ACTIVE)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product  Product    @relation(fields: [productId], references: [id])
  vendor   Vendor     @relation(fields: [vendorId], references: [id])
  purchase Purchase   @relation(fields: [purchaseId], references: [id])
  saleItems SaleItem[]

  @@unique([companyId, batchNumber])
  @@index([companyId, productId])
  @@index([companyId, productId, status])
  @@index([companyId, expiryDate])
  @@index([companyId, availableQuantity])
  @@map("batches")
}

model Customer {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  mobile    String?
  gstNumber String?  @map("gst_number")
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales    Sale[]
  returns  SaleReturn[]
  payments CustomerPayment[]

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, mobile])
  @@map("customers")
}

model Sale {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  customerId    String?       @map("customer_id")
  invoiceNumber String        @map("invoice_number")
  invoiceDate   DateTime      @map("invoice_date")
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  cgstAmount    Decimal       @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal       @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal       @default(0) @map("igst_amount") @db.Decimal(10, 2)
  isInterState  Boolean       @default(false) @map("is_inter_state")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount Decimal       @default(0) @map("balance_amount") @db.Decimal(12, 2)
  paymentMethod PaymentMethod? @map("payment_method")
  status        InvoiceStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  returns  SaleReturn[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, customerId])
  @@index([companyId, invoiceDate])
  @@index([companyId, status])
  @@map("sales")
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String  @map("sale_id")
  productId    String  @map("product_id")
  batchId      String  @map("batch_id")
  quantity     Int
  sellingPrice Decimal @map("selling_price") @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(10, 2)
  cgstRate     Decimal @default(0) @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate     Decimal @default(0) @map("sgst_rate") @db.Decimal(5, 2)
  igstRate     Decimal @default(0) @map("igst_rate") @db.Decimal(5, 2)
  cgstAmount   Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount   Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount   Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)
  taxAmount    Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount  Decimal @map("total_amount") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([batchId])
  @@map("sale_items")
}

model SaleReturn {
  id              String       @id @default(cuid())
  companyId       String       @map("company_id")
  saleId          String       @map("sale_id")
  customerId      String?      @map("customer_id")
  returnNumber    String       @map("return_number")
  returnDate      DateTime     @map("return_date")
  totalAmount     Decimal      @map("total_amount") @db.Decimal(12, 2)
  refundAmount    Decimal      @default(0) @map("refund_amount") @db.Decimal(12, 2)
  reason          String?
  status          ReturnStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale     Sale             @relation(fields: [saleId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  items    SaleReturnItem[]

  @@unique([companyId, returnNumber])
  @@index([companyId])
  @@index([companyId, saleId])
  @@map("sale_returns")
}

model SaleReturnItem {
  id          String  @id @default(cuid())
  returnId    String  @map("return_id")
  productId   String  @map("product_id")
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([productId])
  @@map("sale_return_items")
}

model CustomerPayment {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  customerId    String        @map("customer_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @map("payment_date")
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([companyId])
  @@index([companyId, customerId])
  @@index([companyId, paymentDate])
  @@map("customer_payments")
}

model VendorPayment {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  vendorId      String        @map("vendor_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @map("payment_date")
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@index([companyId])
  @@index([companyId, vendorId])
  @@index([companyId, paymentDate])
  @@map("vendor_payments")
}

model CompanyCounter {
  id              String   @id @default(cuid())
  companyId       String   @unique @map("company_id")
  saleCounter     Int      @default(0) @map("sale_counter")
  purchaseCounter Int      @default(0) @map("purchase_counter")
  returnCounter   Int      @default(0) @map("return_counter")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_counters")
}

model StockAdjustment {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  productId      String         @map("product_id")
  adjustmentType AdjustmentType @map("adjustment_type")
  quantity       Int
  reason         String?
  createdAt      DateTime       @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([companyId, productId])
  @@map("stock_adjustments")
}

// ==================== ENUMS ====================

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

enum InvoiceStatus {
  PAID
  PARTIAL
  UNPAID
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT
}

enum ReturnStatus {
  PENDING
  APPROVED
  COMPLETED
}

enum AdjustmentType {
  INCREASE
  DECREASE
}
